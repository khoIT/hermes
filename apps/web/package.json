{
  "name": "@hermes/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173",
    "prebuild": "tsx scripts/export-feature-catalog.ts",
    "build": "tsc -b && vite build",
    "postbuild": "node scripts/check-no-static-features.cjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@hermes/contracts": "workspace:*",
    "lucide-react": "^0.477.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "recharts": "^2.15.3"
  },
  "devDependencies": {
    "@hermes/tsconfig": "workspace:*",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.5.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vite": "^5.4.19"
  }
}
