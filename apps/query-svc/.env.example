# query-svc — copy to .env and fill in values
NODE_ENV=development
PORT=3002
JWT_SECRET=replace-with-random-32-bytes
TRINO_HOST=
TRINO_HOST_FQDN=
TRINO_PORT=8080
TRINO_USER=
TRINO_PASSWORD=
TRINO_CATALOG=iceberg
TRINO_DEFAULT_SCHEMA=cfm_vn
TRINO_QUERY_TIMEOUT_MS=30000
CATALOG_API_URL=http://localhost:3001/api/v1
DATABASE_URL=postgres://hermes:dev@localhost:5432/hermes
# Driver selection: mock (default, JSONL) | trino (VPN-only)
QUERY_DRIVER=mock
