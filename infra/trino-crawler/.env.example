# Trino connection — copy to .env and fill in real values
# The crawler reads from the root .env; this file is a template only.

TRINO_HOST_FQDN=10.164.54.181
TRINO_PORT=443
TRINO_USER=your_user
TRINO_PASSWORD=your_password
TRINO_CATALOG=iceberg
TRINO_DEFAULT_SCHEMA=cfm_vn

# Optional: override connection timeout (milliseconds, default 10000)
# TRINO_CONNECT_TIMEOUT_MS=10000
