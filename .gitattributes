# Normalize line endings: store LF in the repo, check out per-platform.
# Stops the LF-vs-CRLF churn that floods `git status` on Windows clones.
* text=auto eol=lf

# Shell scripts always LF (so they execute in WSL/git-bash/CI).
*.sh   text eol=lf
*.bash text eol=lf

# Windows-specific scripts always CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Common binary types — never normalize.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.pdf  binary
*.zip  binary
*.gz   binary
*.tgz  binary
*.tar  binary
*.zst  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.otf  binary
*.eot  binary
*.mp4  binary
*.webm binary
*.mov  binary
